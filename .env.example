# Copy to .env and fill in values. Never commit .env to source control.

# ── Feature flags ─────────────────────────────────────────────────────────────
# Set to true to join Marketplace views into HARMONISED + FEATURES layers.
# Requires sql/setup/10_marketplace_sources.sql to have been executed and
# at least one Marketplace listing subscribed in the target SF account.
SURV_USE_MARKETPLACE_DATA=false

# ── Snowflake ─────────────────────────────────────────────────────────────────
SURV_SF_ACCOUNT=<SF_CONNECTION>
SURV_SF_USER=SURVEILLANCE_ADMIN_SVC
SURV_SF_ROLE=SURVEILLANCE_ADMIN
SURV_SF_WAREHOUSE=WH_INGEST
SURV_SF_DATABASE=CRYPTO_SURVEILLANCE
SURV_SF_SCHEMA=RAW
SURV_SF_PRIVATE_KEY=~/.snowflake/rsa_key.p8
# SURV_SF_AUTH=externalbrowser   # use for interactive; key-pair for CI

# ── Ingest method ─────────────────────────────────────────────────────────────
# 'direct'  → INSERT directly into RAW.* tables (fast, no AWS needed)
# 'kinesis' → push to Kinesis → Snowpipe Streaming (exercises full pipeline)
SURV_INGEST_METHOD=direct

# ── Synthetic data tuning ────────────────────────────────────────────────────
SURV_SYNTHETIC_TRADES=50000
SURV_SYNTHETIC_ONCHAIN=10000
SURV_SYNTHETIC_ENTITIES=200
SURV_SYNTHETIC_WALLETS=1000
SURV_SYNTHETIC_SCENARIO=all
SURV_RANDOM_SEED=42

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_DEFAULT_REGION=us-west-2
AWS_ACCOUNT_ID=<AWS_ACCOUNT_ID>
SURV_KINESIS_STREAM_PREFIX=crypto-surveillance

# ── Marketplace DB names (only needed when USE_MARKETPLACE_DATA=true) ────────
SURV_MARKETPLACE_PRICE_DB=CYBERSYN__FINANCIAL_MARKET_DATA
SURV_MARKETPLACE_ONCHAIN_DB=ALLIUM__ONCHAIN_ANALYTICS
SURV_MARKETPLACE_KYC_DB=TRM__CRYPTO_RISK_INTELLIGENCE
