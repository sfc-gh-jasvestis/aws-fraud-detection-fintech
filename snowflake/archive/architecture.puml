@startuml Digital_Asset_Market_Surveillance

!define AWSPuml https://raw.githubusercontent.com/awslabs/aws-icons-for-plantuml/v18.0/dist
!include AWSPuml/AWSCommon.puml
!include AWSPuml/ApplicationIntegration/Kinesis.puml
!include AWSPuml/Storage/SimpleStorageService.puml
!include AWSPuml/Compute/Lambda.puml
!include AWSPuml/Database/Aurora.puml
!include AWSPuml/MachineLearning/Bedrock.puml
!include AWSPuml/BusinessApplications/QuickSight.puml

skinparam backgroundColor #1a1f3a
skinparam defaultFontColor #ffffff
skinparam defaultFontSize 11
skinparam ArrowColor #29B5E8
skinparam ArrowFontColor #29B5E8

skinparam package {
    BackgroundColor #0d1117
    BorderColor #29B5E8
    FontColor #29B5E8
    FontSize 12
    FontStyle bold
}

skinparam rectangle {
    BackgroundColor #1a2744
    BorderColor #29B5E8
    FontColor #ffffff
    RoundCorner 8
}

skinparam database {
    BackgroundColor #1a2744
    BorderColor #29B5E8
    FontColor #ffffff
}

title Digital Asset Market Surveillance & Financial Crime Analytics\nSnowflake + AWS | 2 Warehouses (WH_SURVEILLANCE M + WH_ML L) | 9 SQL Files (00-08)

' LAYER 0: CEX Exchange Infrastructure
package "CEX Exchange Infrastructure (AWS Account: 018437500440)" as CEX_INFRA {
    rectangle "Matching Engine\n(EC2 / ECS)" as ME
    rectangle "Order Book Service\n(EC2 / ECS)" as OB
    database "Balance / Account\n(Aurora PostgreSQL)" as BAL
    rectangle "System & App Logs\n(CloudWatch Logs)" as SYS_LOGS
}

package "On-Chain Data Sources" as ONCHAIN {
    rectangle "Blockchain Indexer\n(Lambda / ECS)" as IDX
    rectangle "3rd-Party Providers\n(Chainalysis, TRM, Nansen)" as PROV
}

' LAYER 1: AWS Ingestion
package "AWS Ingestion Layer" as AWS_INGEST {
    Kinesis(KDS, "Kinesis Data Streams\ncex-trades | cex-orders\ncex-balances | cex-logs", "real-time stream")
    Lambda(LAM, "Lambda Functions\non-chain normalizer\nlog parser", "event processing")
    rectangle "Kinesis Firehose\n-> S3 (batch / logs)" as FIRE
    SimpleStorageService(S3_RAW, "s3://crypto-surveillance-raw\n(landing zone)", "raw events")
}

' LAYER 2: Snowflake RAW
package "Snowflake: CRYPTO_SURVEILLANCE.RAW (demo43)" as SF_RAW {
    rectangle "Snowpipe Streaming\n(Kinesis -> Snowflake SDK)" as SP_STREAM
    rectangle "Snowpipe Batch\n(S3 -> External Stage)" as SP_BATCH
    database "CEX_TRADES_RAW\nCEX_ORDERS_RAW\nCEX_BALANCES_RAW\nCEX_LOGS_RAW\nONCHAIN_EVENTS_RAW" as RAW_TABLES
    database "DLQ_ERRORS\n(malformed records)" as DLQ
}

' LAYER 3: Snowflake HARMONISED
package "Snowflake: CRYPTO_SURVEILLANCE.HARMONISED" as SF_HARM {
    database "Dynamic Tables (WH_SURVEILLANCE):\nTRADES | ORDERS\nBALANCES_SNAPSHOT | ONCHAIN_TRANSFERS" as HARM_TABLES
    database "ENTITY\n(KYC attrs, risk_rating, PII-tagged)" as ENTITY
    database "WALLET\n(chain, owner, tags:\nmixer/sanctioned/exchange)" as WALLET
    database "ENTITY_RELATION\n(entity-wallet-counterparty graph)" as RELS
    rectangle "VW_SYNTHETIC_PRICES\nVW_SYNTHETIC_WALLET_LABELS" as SYNTH
}

' LAYER 4: Snowflake FEATURES
package "Snowflake: CRYPTO_SURVEILLANCE.FEATURES" as SF_FEAT {
    database "TRADE_FEATURES\nrolling vol/freq\nwash-trade indicators" as TF
    database "ENTITY_FEATURES\nwallet exposure\nvelocity, burst clusters" as EF
}

' LAYER 5: Analytics + AI
package "Snowflake: CRYPTO_SURVEILLANCE.ANALYTICS + ML" as SF_AI {
    rectangle "Detection Rules (6 SQL Views):\nPump & Dump | Wash Trades\nCross-Exchange | Sanctions\nStructuring | Mixer Exposure" as RULES
    rectangle "Snowpark ML (XGBoost)\nFraud/AML Scorer UDF\n(WH_ML for training)" as ML_UDF
    database "ANALYTICS.ALERTS\n(severity, reason_code\nml_score, rule_flags)" as ALERTS
    database "ANALYTICS.CASES\n(case lifecycle, owner\nstate, SLA, root_alerts)" as CASES
}

' LAYER 6: Bedrock Agentic
package "Amazon Bedrock -- Agentic Layer" as BEDROCK_LAYER {
    Bedrock(CLAUDE, "Claude LLM\n(Bedrock API)", "LLM inference")
    rectangle "SP_GENERATE_CASE_NARRATIVE\n(Snowpark External Access + SigV4)" as SP_NAR
}

' LAYER 7: Consumption
package "Consumption Layer" as CONSUME {
    rectangle "Streamlit in Snowflake\nInvestigator Copilot UI\n* Case list & filters\n* Trade graph + on-chain flows\n* Explain this case (Bedrock)" as STLIT
    QuickSight(QS, "Amazon QuickSight\nAlert Volume | Entity Heatmap\nCase SLA | Trading Summary\nOn-Chain Flows", "BI dashboards")
    database "VW_KRIs / VW_KPIs\n(exec reporting views)" as VW_KRI
}

' GOVERNANCE OVERLAY
package "Governance (Snowflake Horizon)" as GOV {
    rectangle "Masking Policies\n(PII / KYC fields)" as MASK
    rectangle "Row Access Policies\n(role-based case scoping)" as RAP
    rectangle "Object Tags + Lineage\nData Classification" as TAG
}

' CONNECTIONS
ME -down-> KDS : trade/order events
OB -down-> KDS : order book snapshots
BAL -down-> KDS : CDC via DMS
SYS_LOGS -down-> FIRE : log subscription

IDX -down-> LAM : block events
PROV -down-> LAM : wallet intel API
LAM -down-> KDS
LAM -down-> S3_RAW

FIRE -down-> S3_RAW

KDS -down-> SP_STREAM : Snowpipe Streaming SDK
S3_RAW -down-> SP_BATCH : SQS notification

SP_STREAM -down-> RAW_TABLES
SP_BATCH -down-> RAW_TABLES
RAW_TABLES -right-> DLQ : parse errors

RAW_TABLES -down-> HARM_TABLES : Dynamic Tables (1 min lag)
RAW_TABLES -down-> ENTITY
RAW_TABLES -down-> WALLET
ENTITY -right-> RELS
WALLET -right-> RELS
HARM_TABLES -right-> SYNTH : derived views

HARM_TABLES -down-> TF : Snowpark
ENTITY -down-> EF
WALLET -down-> EF
RELS -down-> EF

TF -down-> RULES
EF -down-> RULES
TF -down-> ML_UDF
EF -down-> ML_UDF
RULES -down-> ALERTS
ML_UDF -down-> ALERTS
ALERTS -down-> CASES

CASES -right-> SP_NAR : case_id context
SP_NAR <-right-> CLAUDE : Bedrock API (External Access)

CASES -down-> STLIT
SP_NAR -down-> STLIT : SAR narrative
ALERTS -down-> QS
CASES -down-> QS
ALERTS -down-> VW_KRI
VW_KRI -right-> QS

ENTITY .right. MASK : tagged + masked
TAG .right. HARM_TABLES

@enduml
