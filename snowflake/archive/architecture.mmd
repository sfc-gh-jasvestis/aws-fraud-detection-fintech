%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#1a1f3a', 'primaryTextColor': '#ffffff', 'primaryBorderColor': '#29B5E8', 'lineColor': '#29B5E8', 'secondaryColor': '#0d1117', 'tertiaryColor': '#1a2744'}}}%%
flowchart TB
    subgraph CEX["CEX / Exchange Infrastructure (AWS)"]
        direction TB
        ME["Matching Engine\n(EC2 / ECS)"]
        OB["Order Book Service\n(EC2 / ECS)"]
        BAL["Balance / Account\n(Aurora PostgreSQL)"]
        LOGS["System & App Logs\n(CloudWatch Logs)"]
    end

    subgraph ONCHAIN["On-Chain Data Sources"]
        direction TB
        IDX["Blockchain Indexer\n(Lambda / ECS)"]
        EXT["3rd-Party Providers\n(Chainalysis, TRM, Nansen)"]
    end

    subgraph AWS_INGEST["AWS Ingestion Layer"]
        direction TB
        KDS["Kinesis Data Streams\ncex-trades | cex-orders\ncex-balances | cex-logs"]
        FIRE["Kinesis Firehose\n-> S3 (batch/logs)"]
        S3_RAW["S3: crypto-surveillance-raw\n(landing zone)"]
        LAM["Lambda Functions\non-chain normalizer\nlog parser"]
    end

    subgraph SF_RAW["Snowflake RAW Layer  (CRYPTO_SURVEILLANCE.RAW)"]
        direction TB
        SP_STREAM["Snowpipe Streaming\n(Kinesis -> Snowflake SDK)"]
        SP_BATCH["Snowpipe Batch\n(S3 -> External Stage)"]
        RT["CEX_TRADES_RAW\nCEX_ORDERS_RAW\nCEX_BALANCES_RAW\nONCHAIN_EVENTS_RAW"]
        DLQ["DLQ_ERRORS\n(malformed records)"]
    end

    subgraph SF_HARM["Snowflake HARMONISED Layer"]
        direction TB
        DT1["Dynamic Tables (WH_SURVEILLANCE):\nTRADES | ORDERS\nBALANCES_SNAPSHOT\nONCHAIN_TRANSFERS"]
        ENTITY["ENTITY (KYC attributes\nrisk rating, PII-tagged)"]
        WALLET["WALLET (chain, owner\ntags: mixer/sanctioned)"]
        RELS["ENTITY_RELATION\n(entity-wallet-counterparty)"]
        SYNTH["VW_SYNTHETIC_PRICES\nVW_SYNTHETIC_WALLET_LABELS"]
    end

    subgraph SF_FEAT["Snowflake FEATURES Layer"]
        direction TB
        TF["TRADE_FEATURES\nrolling vol, freq\nwash-trade indicators"]
        EF["ENTITY_FEATURES\nwallet exposure\nvelocity, burst"]
    end

    subgraph SF_AI["Snowflake ANALYTICS + ML Layer"]
        direction TB
        RULES["Detection Rules (SQL Views):\nPump & Dump | Wash Trades\nCross-Exchange | Sanctions\nStructuring | Mixer Exposure"]
        ML["Snowpark ML (XGBoost)\nFraud/AML Scorer UDF\n(WH_ML for training)"]
        ALERTS["ANALYTICS.ALERTS\n(severity, reason codes\nML score + rule flags)"]
        CASES["ANALYTICS.CASES\n(case lifecycle\nowner, state, SLA)"]
    end

    subgraph BEDROCK["Amazon Bedrock (Agentic Layer)"]
        direction TB
        CLAUDE["Claude LLM\n(via Bedrock API)"]
        SP_NAR["SP_GENERATE_CASE_NARRATIVE\n(Snowpark External Access)"]
    end

    subgraph CONSUME["Consumption Layer"]
        direction TB
        STLIT["Streamlit in Snowflake\nInvestigator Copilot UI\n- Case list & filters\n- Trade graph & on-chain flows\n- Explain this case (Bedrock)"]
        QS["Amazon QuickSight\nVW_QUICKSIGHT_ALERT_VOLUME\nVW_QUICKSIGHT_ENTITY_HEATMAP\nVW_QUICKSIGHT_CASE_SLA\nVW_QUICKSIGHT_TRADING_SUMMARY\nVW_QUICKSIGHT_ONCHAIN_FLOWS"]
        VW_KRI["VW_KRIs / VW_KPIs\n(exec reporting views)"]
    end

    subgraph GOV["Governance (Snowflake Horizon)"]
        direction TB
        MASK["Masking Policies\n(PII / KYC fields)"]
        RAP["Row Access Policies\n(role-based case scoping)"]
        TAG["Object Tags + Lineage\nData Classification"]
    end

    ME -->|"trade/order events"| KDS
    OB -->|"order book snapshots"| KDS
    BAL -->|"CDC via DMS"| KDS
    LOGS -->|"log subscription"| FIRE

    IDX -->|"block events"| LAM
    EXT -->|"wallet intel API"| LAM
    LAM --> KDS
    LAM --> S3_RAW

    FIRE --> S3_RAW

    KDS -->|"Snowpipe Streaming SDK"| SP_STREAM
    S3_RAW -->|"SQS notification"| SP_BATCH

    SP_STREAM --> RT
    SP_BATCH --> RT
    RT -->|"parse errors"| DLQ

    RT --> DT1
    RT --> ENTITY
    RT --> WALLET
    ENTITY --> RELS
    WALLET --> RELS
    DT1 --> SYNTH

    DT1 --> TF
    ENTITY --> EF
    WALLET --> EF
    RELS --> EF

    TF --> RULES
    EF --> RULES
    TF --> ML
    EF --> ML
    RULES --> ALERTS
    ML --> ALERTS
    ALERTS --> CASES

    CASES -->|"case_id context"| SP_NAR
    SP_NAR -->|"Snowpark External Access\n(Network Rule + API Integration)"| CLAUDE
    CLAUDE -->|"narrative / SAR draft"| SP_NAR

    CASES --> STLIT
    SP_NAR --> STLIT
    ALERTS --> QS
    CASES --> QS
    ALERTS --> VW_KRI
    VW_KRI --> QS

    ENTITY -.->|"tagged + masked"| MASK
    MASK -.-> RAP
    TAG -.-> DT1

    classDef awsStyle fill:#FF9900,stroke:#FF9900,color:#000000
    classDef sfStyle fill:#29B5E8,stroke:#29B5E8,color:#000000
    classDef bedrockStyle fill:#7B68EE,stroke:#7B68EE,color:#ffffff
    classDef govStyle fill:#2D8653,stroke:#2D8653,color:#ffffff
    classDef consumeStyle fill:#1a6b3c,stroke:#1a6b3c,color:#ffffff

    class CEX,ONCHAIN,AWS_INGEST awsStyle
    class SF_RAW,SF_HARM,SF_FEAT,SF_AI sfStyle
    class BEDROCK bedrockStyle
    class GOV govStyle
    class CONSUME consumeStyle
